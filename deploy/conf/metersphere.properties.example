# MeterSphere production config (file mode, no Nacos)
# Copy to server as: /opt/metersphere/conf/metersphere.properties
# Replace ALL <placeholders> with real values. NEVER commit the filled-in file.

# MySQL
spring.datasource.url=jdbc:mysql://<mysql-host>:3306/metersphere?autoReconnect=false&useUnicode=true&characterEncoding=UTF-8&characterSetResults=UTF-8&zeroDateTimeBehavior=convertToNull&allowPublicKeyRetrieval=true&useSSL=false&serverTimezone=Asia/Shanghai
spring.datasource.username=<mysql-user>
spring.datasource.password=<change-me>

# Kafka
kafka.bootstrap-servers=<kafka-host>:9092

# MinIO
minio.endpoint=http://<minio-host>:9000
minio.access-key=<minio-access-key>
minio.secret-key=<change-me>

# Paths inside container (must match volume mounts)
logging.file.path=/opt/metersphere/logs/metersphere
spring.redis.redisson.file=file:/opt/metersphere/conf/redisson.yml
jmeter.home=/opt/jmeter

run.mode=standalone

logger.level=INFO
logger.sql.level=info
