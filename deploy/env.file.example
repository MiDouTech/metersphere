# MeterSphere production runtime env (file mode — no Nacos)
# Copy to server as /opt/metersphere/env.file and fill in real values.
# NEVER commit env.file or real secrets to git.

# ---- Profile (required) ----
# local: disable Nacos, load /opt/metersphere/conf/metersphere.properties
SPRING_PROFILES_ACTIVE=local

# ---- Image ----
MS_IMAGE=docker.cnb.cool/miduoyanfa/middleground/metersphere/metersphere-backend:latest
MS_CONTAINER_NAME=metersphere

# ---- Host paths (mounted into container) ----
# conf must contain metersphere.properties + redisson.yml
MS_CONF_DIR=/opt/metersphere/conf
# If host logs live under /data/..., set e.g. MS_LOG_DIR=/data/metersphere/logs
MS_LOG_DIR=/opt/metersphere/logs

# ---- Ports ----
# Bind only on internal IP if needed, e.g. MS_HTTP_BIND=10.0.1.1:
MS_HTTP_BIND=
MS_HTTP_PORT=8081
MS_TCP_PORT=7071
